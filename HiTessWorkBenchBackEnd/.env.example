# === DB 접속 정보 ===
DB_USER=admin
DB_PASSWORD=비밀번호입력
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hitessworkbench

# === AI 설정 (선택, Ollama 사용 시) ===
# AI 학습 문서 폴더 경로 (PDF/DOCX/TXT)
REPORTS_DIR=C:\경로\reports_data
# Ollama 서버 주소 (같은 서버면 기본값 사용)
OLLAMA_BASE_URL=http://localhost:11434

# === Tesseract OCR (선택, 이미지 PDF 처리 시) ===
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# === 클라이언트 배포 (선택, 기본값: 백엔드 폴더 내 LastestVersionProgram) ===
# LATEST_CLIENT_DIR=C:\경로\LastestVersionProgram
